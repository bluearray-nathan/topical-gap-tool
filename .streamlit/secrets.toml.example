# Copy this into your Streamlit secrets (Streamlit Cloud: app settings > Secrets,
# or locally: .streamlit/secrets.toml). Do not commit the real file.

[openai]
api_key = "sk-your-openai-key"          # used for coverage scoring, entity clustering, embeddings

[google]
gemini_api_key = "your-gemini-key"        # used for fan-out generation (Google Search grounding)

[serpapi]
api_key = "your-serpapi-key"              # optional; enables competitor auto-suggestions

# Optional: override model names without touching code (a model rename will not break the app)
[models]
gemini = "gemini-3-flash-preview"
openai = "gpt-5.4-mini"
embedding = "text-embedding-3-small"

# Optional: route page fetches through a proxy
[proxy]
server = "http://host:port"
username = ""
password = ""

# Optional: custom crawler user agent
[crawler]
user_agent = "QueryFanOutBot/1.0"
